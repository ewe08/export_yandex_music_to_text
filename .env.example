# Яндекс Музыка - токен авторизации (ОПЦИОНАЛЬНО)
# Токен нужен только для приватных плейлистов
# Для публичных плейлистов можно оставить пустым или закомментировать
# Получите токен через OAuth: https://oauth.yandex.ru/
# Либо https://yandex-music.readthedocs.io/en/main/token.html
TOKEN=your_yandex_music_token_here

# UUID плейлиста для экспорта (ОБЯЗАТЕЛЬНО)
# Найдите UUID в URL: https://music.yandex.ru/playlists/{UUID}
# Пример: lk.f157faa1-5284-4dd9-86eb-bd5e6a009fe0
PLAYLIST_UUID=your_playlist_uuid_here


